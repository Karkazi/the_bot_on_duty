# IANA (Europe/Moscow по умолчанию)
BOT_TIMEZONE=Europe/Moscow
# Каталог данных: state.json, logs/, tmp/, archive/
# Docker: BOT_APP_DATA_DIR=/app/data  (volume: /root/the_bot_on_duty_2/data:/app/data)
# Сервер без Docker: BOT_APP_DATA_DIR=/root/the_bot_on_duty_2/data
# BOT_APP_DATA_DIR=/app/data

JIRA_LOGIN_URL=https://jira.example.com/login.jsp
JIRA_BROWSE_URL_TEMPLATE=https://jira.example.com/browse/{issue_key}
JIRA_USERNAME=
JIRA_PASSWORD=
JIRA_TOKEN=
# Поле Jira для фиксации времени окончания сбоя при закрытии (stop_alarm).
# В Jira Petrovich: «Время окончания сбоя» = customfield_13120
JIRA_TIME_END_PROBLEM_FIELD=customfield_13120

CONFLUENCE_LOGIN_URL=https://confluence.example.com/login.action
CONFLUENCE_TARGET_URL=https://confluence.example.com/pages/viewpage.action?pageId=0
CONFLUENCE_WORKS_PAGE_ID=
CONFLUENCE_LABEL_URL=
CONFLUENCE_LABEL_NAME=
CONFLUENCE_LABEL_SPACE=
CONFLUENCE_USERNAME=
CONFLUENCE_PASSWORD=
CONFLUENCE_TOKEN=

SIMPLEONE_BASE_URL=https://simpleone.example.com
SIMPLEONE_TOKEN=
SIMPLEONE_GROUP_ID=
SIMPLEONE_USERNAME=
SIMPLEONE_PASSWORD=
SIMPLEONE_COMMENTS_API_SCOPE=
SIMPLEONE_COMMENTS_API_PATH=
SIMPLEONE_PROXY_URL=

MAX_API_URL=https://platform-api.max.ru
MAX_BOT_TOKEN=
MAX_ALARM_CHANNEL_ID=
MAX_ALARM_MAIN_CHAT_ID=
MAX_ALARM_FA_CHAT_1_ID=
MAX_ALARM_FA_CHAT_2_ID=
MAX_ALARM_FA_CHAT_3_ID=
MAX_ALARM_FA_CHAT_4_ID=
MAX_ALARM_FA_CHAT_1_LINK=
MAX_ALARM_FA_CHAT_2_LINK=
MAX_ALARM_FA_CHAT_3_LINK=
MAX_ALARM_FA_CHAT_4_LINK=
MAX_ALARM_FA_CHAT_JOIN_LINK=
MAX_CHAT_LINK_TEMPLATE=https://web.max.ru/chat/{chat_id}
MAX_ALARM_FA_CHAT_DELETE_ON_CLOSE=false
MAX_BOT_USER_ID=
MAX_ADMIN_IDS=
MAX_CALENDAR_ADMIN_IDS=
MAX_MANAGEMENT_ENABLED=true

# Ежедневная сводка работ из Confluence (слоты по BOT_TIMEZONE)
CALENDAR_DIGEST_ENABLED=1
CALENDAR_DIGEST_TIMES=10:00,18:00

# Пинг ответственных в FA-чате при создании сбоя
RESPONSIBLES_ENABLED=1
RESPONSIBLES_CONFLUENCE_PAGE_ID=304990042
RESPONSIBLES_CONFLUENCE_PAGE_URL=
RESPONSIBLES_CACHE_TTL_SEC=900
RESPONSIBLES_NOTIFY_ON_MISS=1
#
# Фича-флаг: включать/выключать привлечение ответственных за сервис (CallMasterService).
# 0 — не работает, 1 — работает.
CALL_MASTER_SERVICE_ENABLED=1

KTALK_EMERGENCY_URL=
